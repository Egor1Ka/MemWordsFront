# ── Build-time (baked into the image; passed as docker build-args in CI) ──────
# Browser-facing API origin used by the Google login button. Leave EMPTY in
# production so the button uses a same-origin relative URL (/api/auth/google),
# which Caddy proxies to the backend.
NEXT_PUBLIC_API_URL=
# Canonical site URL for SEO / Open Graph / sitemap / robots.
NEXT_PUBLIC_SITE_URL=https://memwords.uk

# ── Runtime (set in docker-compose for the "web" service) ────────────────────
# Server-to-server base URL the Next server uses to reach the backend
# (SSR getUser). Internal docker network hostname = the "api" service.
BACKEND_URL=http://api:9000

# ── Local dev only ───────────────────────────────────────────────────────────
# For local dev point both at the backend directly, e.g.:
# BACKEND_URL=http://127.0.0.1:9000
# NEXT_PUBLIC_API_URL=http://localhost:9000
